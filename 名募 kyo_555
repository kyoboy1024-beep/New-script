-- 自動反撃の処理
local function getNearestAttacker()
    local nearest, dist = nil, 30
    local myRoot = getRoot()
    if not myRoot then return nil end
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LP and player.Character then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local d = (hrp.Position - myRoot.Position).Magnitude
                if d < dist then
                    dist = d
                    nearest = player
                end
            end
        end
    end
    return nearest
end

local function counterAttack(attacker)
    if not attacker or not attacker.Character then return end
    local targetRoot = attacker.Character:FindFirstChild("HumanoidRootPart")
    if not targetRoot then return end
    
    if InvSettings.counterMode == "反発" then
        local bv = Instance.new("BodyVelocity", targetRoot)
        bv.Velocity = Vector3.new(0, 100, 0)
        bv.MaxForce = Vector3.one * math.huge
        Debris:AddItem(bv, 1)
    elseif InvSettings.counterMode == "凍結" then
        local bp = Instance.new("BodyPosition", targetRoot)
        bp.Position = targetRoot.Position
        bp.MaxForce = Vector3.one * math.huge
        bp.P = 1e6
        Debris:AddItem(bp, 3)
    elseif InvSettings.counterMode == "デス" then
        attacker.Character:BreakJoints()
    elseif InvSettings.counterMode == "キック" then
        local blob = BlobmanFeature.getBlobman()
        if not blob then
            BlobmanFeature.spawnBlobman()
            task.wait(0.5)
            blob = BlobmanFeature.getBlobman()
        end
        if blob and BlobmanFeature.isSittingOnBlobman() then
