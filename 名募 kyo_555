local loopSelectedPlayers = {}
local isKilling = false
local isBringing = false
local loopNoclipConnection = nil
local loopNoclipping = false

local GrabEventsFolder = ReplicatedStorage:WaitForChild("GrabEvents")
local DestroyGrabLine = GrabEventsFolder:WaitForChild("DestroyGrabLine")
local SetNetworkOwnerLoop = GrabEventsFolder:WaitForChild("SetNetworkOwner")

local function lookAt(from, to)
    local direction = (to - from).Unit
    local right = direction:Cross(Vector3.new(0, 1, 0))
    local up = right:Cross(direction)
    return CFrame.fromMatrix(from, right, up)
end

local function EnableLoopNoclip()
    if not loopNoclipConnection then
        loopNoclipping = false
        loopNoclipConnection = RunService.Stepped:Connect(function()
            if loopNoclipping == false and LP.Character then
                for _, part in pairs(LP.Character:GetChildren()) do
                    if part:IsA("BasePart") and part.CanCollide and part.Name ~= "floatName" then
                        part.CanCollide = false
                    end
                end
            end
        end)
    end
end

local function DisableLoopNoclip()
    if loopNoclipConnection then
        loopNoclipConnection:Disconnect()
        loopNoclipConnection = nil
    end
    loopNoclipping = true
end

local function SNOWship(part)
    if part and typeof(part) == "Instance" then
        local distance = LP:DistanceFromCharacter(part.Position)
        if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") and distance <= 30 then
            SetNetworkOwnerLoop:FireServer(part, lookAt(LP.Character.HumanoidRootPart.Position, part.Position))
        end
    end
end

local function TeleportPlayerLoop(cf)
    local character = LP.Character
    if character and typeof(cf) == "CFrame" then
        local root = character:FindFirstChild("HumanoidRootPart")
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if root and humanoid then
            root.CFrame = root.CFrame.Rotation + cf.Position
            if humanoid.SeatPart == nil or tostring(humanoid.SeatPart.Parent) ~= "CreatureBlobman" then
                humanoid.Sit = false
            end
        end
    end
end

local function CreateSkyVelocity(part)
    if not part:FindFirstChild("SkyVelocity") then
        local bv = Instance.new("BodyVelocity", part)
        bv.Name = "SkyVelocity"
        bv.Velocity = Vector3.new(0, 100000000000000, 0)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    end
end

local function CheckNetworkOwnership(player)
    if typeof(player) == "Instance" and player:IsA("Player") and player.Character then
        local head = player.Character:FindFirstChild("Head")
        if head and head:FindFirstChild("PartOwner") and head.PartOwner.Value == LP.Name then
            return true
        end
    end
    return false
end

local function IsValidTarget(player)
    if typeof(player) == "Instance" and player ~= LP then
        if player:IsA("Player") and player.Character then
            if player.Character:IsDescendantOf(Workspace) then
                local root = player.Character:FindFirstChild("HumanoidRootPart")
                local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                if root and humanoid and humanoid.Health > 0 then
                    if player:FindFirstChild("InPlot") and player.InPlot.Value then return false end
                    if humanoid.FloorMaterial == Enum.Material.Air then return false end
                    return true
                end
            end
        end
    end
    return false
end

local function KillPlayer(targetPlayer)
    if not IsValidTarget(targetPlayer) then return end
    local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local humanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
    if not root or not humanoid then return end
    
    local initialPos = LP.Character.HumanoidRootPart.CFrame
    EnableLoopNoclip()
    
    for i = 1, 50 do
        SNOWship(root)
        if CheckNetworkOwnership(targetPlayer) or root.AssemblyLinearVelocity.Magnitude > 500 then
            CreateSkyVelocity(root)
            pcall(function() DestroyGrabLine:FireServer(root) end)
            break
        end
        task.wait()
        if root.Position.Y <= -12 then
            TeleportPlayerLoop(CFrame.new(root.Position + Vector3.new(0, 5, -15)))
        else
            TeleportPlayerLoop(CFrame.new(root.Position + Vector3.new(0, -10, -10)))
        end
        humanoid.BreakJointsOnDeath = false
        humanoid:ChangeState(Enum.HumanoidStateType.Dead)
        humanoid.Jump = true
        humanoid.Sit = false
    end
    
    DisableLoopNoclip()
    TeleportPlayerLoop(initialPos)
end

local function BringPlayer(targetPlayer)
    if not IsValidTarget(targetPlayer) then return end
    local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local humanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
    if not root or not humanoid then return end
    
    local initialPos = LP.Character.HumanoidRootPart.CFrame
    local myPos = LP.Character.HumanoidRootPart.Position
    EnableLoopNoclip()
    
    for i = 1, 50 do
        SNOWship(root)
        if CheckNetworkOwnership(targetPlayer) then
            root.CFrame = CFrame.new(myPos + Vector3.new(0, 3, 0))
            pcall(function() DestroyGrabLine:FireServer(root) end)
            break
        end
        task.wait()
        if root.Position.Y <= -12 then
            TeleportPlayerLoop(CFrame.new(root.Position + Vector3.new(0, 5, -15)))
        else
            TeleportPlayerLoop(CFrame.new(root.Position + Vector3.new(0, -10, -10)))
        end
        humanoid.Jump = true
        humanoid.Sit = false
    end
    
    DisableLoopNoclip()
    TeleportPlayerLoop(initialPos)
end

local function UpdateLoopPlayerList()
    local options = {}
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LP then
            local alreadySelected = false
            for _, selected in ipairs(loopSelectedPlayers) do
                if selected == player.Name then alreadySelected = true break end
            end
            if not alreadySelected then
                table.insert(options, player.Name .. " (" .. player.DisplayName .. ")")
            end
        end
    end
    table.sort(options)
    return options
end

