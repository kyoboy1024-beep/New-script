-- ★ Remove Anti Input Lag 機能 ★
local function startAntiInputLag()
    if antiInputLagRunning then return end
    antiInputLagRunning = true
    
    task.spawn(function()
        local plr = LP
        local char = plr.Character or plr.CharacterAdded:Wait()
        local hrp = char:WaitForChild("HumanoidRootPart")
        local SpawnRemote = ReplicatedStorage:WaitForChild("MenuToys"):WaitForChild("SpawnToyRemoteFunction")
        
        while InvSettings.antiInputLag do
            local toysFolder = Workspace:FindFirstChild(plr.Name .. "SpawnedInToys")
            if not toysFolder then
                task.wait(0.1)
                continue
            end
            
            local toy = toysFolder:FindFirstChild(antiInputLagToy)
            
            if not toy then
                pcall(function()
                    SpawnRemote:InvokeServer(
                        antiInputLagToy,
                        hrp.CFrame * CFrame.new(0, 5, 0),
                        Vector3.zero
                    )
                end)
                
                local t0 = tick()
                repeat
                    RunService.Heartbeat:Wait()
                    toysFolder = Workspace:FindFirstChild(plr.Name .. "SpawnedInToys")
                    toy = toysFolder and toysFolder:FindFirstChild(antiInputLagToy)
                until toy or tick() - t0 > 1 or not InvSettings.antiInputLag
            end
            
            if toy and toy.Parent then
                local holdPart = toy:FindFirstChild("HoldPart")
                if holdPart then
                    local holdingPlayer = holdPart:FindFirstChild("HoldingPlayer")
                    holdingPlayer = holdingPlayer and holdingPlayer.Value
                    
                    if holdingPlayer and holdingPlayer ~= plr then
                        pcall(function()
                            holdPart.DropItemRemoteFunction:InvokeServer(
                                toy,
                                hrp.CFrame * CFrame.new(0, 2000, 0),
                                Vector3.zero
                            )
                        end)
                        toy:Destroy()
                    else
                        pcall(function()
                            holdPart.HoldItemRemoteFunction:InvokeServer(toy, char)
                        end)
                        task.wait(0.05)
                        pcall(function()
                            holdPart.DropItemRemoteFunction:InvokeServer(
                                toy,
                                hrp.CFrame * CFrame.new(0, 2000, 0),
                                Vector3.zero
                            )
                        end)
                        task.wait(0.01)
                    end
                end
            end
            RunService.Heartbeat:Wait()
        end
        antiInputLagRunning = false
    end)
end

