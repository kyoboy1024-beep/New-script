local gucciAllowSeat = false
local GUCCI_ANTI_DURATION = 3.2

local function gucciGetChar() return LP.Character or LP.CharacterAdded:Wait() end
local function gucciGetBlobman()
    local f = Workspace:FindFirstChild(LP.Name .. "SpawnedInToys")
    return f and f:FindFirstChild("CreatureBlobman")
