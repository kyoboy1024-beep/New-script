local iconTemplate = createIconTemplate()

local function createIconOnPlayer(player)
    if player == LP then return end
    if not player.Character then return end
    local head = player.Character:FindFirstChild("Head")
    if not head then return end
    if player.Character:FindFirstChild("ESP_Icon") then return end
    
    local icon = iconTemplate:Clone()
    icon.Parent = player.Character
    icon.Adornee = head
    icon.Username.Text = player.DisplayName or player.Name
    
    local success, result = pcall(function()
        return game:HttpGet("https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds=" .. player.UserId .. "&size=420x420&format=png")
    end)
    if success and result then
        local data = game:GetService("HttpService"):JSONDecode(result)
        if data and data.data and data.data[1] and data.data[1].imageUrl then
            icon.UserImage.Image = data.data[1].imageUrl
        end
    end
end

