                if plr ~= LP then
                    if plr.Character then
                        createIconOnPlayer(plr)
                    end
                    espIconConnections[#espIconConnections + 1] = plr.CharacterAdded:Connect(function()
                        createIconOnPlayer(plr)
                    end)
                end
            end
            
            -- 新規プレイヤー追加時の監視
            espIconPlayerAdded = Players.PlayerAdded:Connect(function(plr)
                if plr ~= LP then
                    espIconConnections[#espIconConnections + 1] = plr.CharacterAdded:Connect(function()
                        createIconOnPlayer(plr)
                    end)
                end
            end)
            
            -- アイコン維持ループ
