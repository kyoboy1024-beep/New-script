Workspace.ChildAdded:Connect(function(model)
    if model.Name ~= "GrabParts" then return end
    
    task.spawn(function()
        local grabPart = model:WaitForChild("GrabPart", 1)
        if not grabPart then return end
        task.wait()
        
        local weld = grabPart:FindFirstChild("WeldConstraint")
        local part1 = weld and weld.Part1
        
        if not part1 then
            task.wait()
            weld = grabPart:FindFirstChild("WeldConstraint")
            part1 = weld and weld.Part1
        end
        
        if part1 and LP.Character and part1:IsDescendantOf(LP.Character) then return end
        if grabPart and LP.Character and grabPart:IsDescendantOf(LP.Character) then return end
        if model and LP.Character and model:IsDescendantOf(LP.Character) then return end
        
        if grabFlags.KillGrab and part1 then
            pcall(function() part1.Parent:BreakJoints() end)
        end
        
        if grabFlags.SkyGrab and part1 then
            local bv = Instance.new("BodyVelocity", part1)
            bv.Velocity = Vector3.new(0, 100, 0)
            bv.MaxForce = Vector3.new(0, math.huge, 0)
            Debris:AddItem(bv, 1.5)
        end
        
        if grabFlags.SpinGrab and part1 then
            pcall(function()
                local bav = Instance.new("BodyAngularVelocity", part1)
                bav.AngularVelocity = Vector3.new(0, 1000, 0)
                bav.MaxTorque = Vector3.one * math.huge
            end)
        end
        
        if grabFlags.FreezeGrab and part1 then
            for _, child in ipairs(model:GetDescendants()) do
                if child:IsA("BasePart") then
                    child.Anchored = true
                end
            end
        end
        
        if grabFlags.FlingGrab and part1 then
            pcall(function()
                setNetworkOwner(part1)
                applyVelocity(part1, Vector3.new(math.random(-100, 100), 200, math.random(-100, 100)))
            end)
        end
        
        if grabFlags.VoidGrab and part1 then
            pcall(function()
                setNetworkOwner(part1)
                applyVelocity(part1, Vector3.new(0, -500, 0))
            end)
        end
        
        if grabFlags.PoisonGrab and part1 then
            pcall(function()
                local head = part1.Parent:FindFirstChild("Head")
                if head and #poisonHurtParts > 0 then
                    updatePoisonParts()
                    while Workspace:FindFirstChild("GrabParts") do
                        for _, p in pairs(poisonHurtParts) do
                            p.Size = Vector3.new(2, 2, 2)
                            p.Transparency = 1
                            p.Position = head.Position
                        end
                        task.wait()
                        for _, p in pairs(poisonHurtParts) do
                            p.Position = Vector3.new(0, -200, 0)
                        end
                    end
                end
            end)
        end
        
        if grabFlags.RagdollGrab and part1 then
            local ragdollRemote = ReplicatedStorage.CharacterEvents:FindFirstChild("RagdollRemote")
            if ragdollRemote then
                pcall(function() ragdollRemote:FireServer(part1, 999999) end)
            end
        end
        
        if grabFlags.FireGrab and part1 then
            pcall(function()
                local head = part1.Parent:FindFirstChild("Head")
                if head then applyFire(head) end
            end)
        end
        
        if grabFlags.NoclipGrab then
            if noclipGrabCo and coroutine.status(noclipGrabCo) ~= "dead" then
                coroutine.close(noclipGrabCo)
            end
            noclipGrabCo = coroutine.create(noclipGrabLoopFunc)
            coroutine.resume(noclipGrabCo)
        end
        
        if grabFlags.KickGrab then
            enableKickGrab()
        elseif not grabFlags.KickGrab and #kickGrabConnections > 0 then
            disableKickGrab()
        end
        
        if grabFlags.StrengthEnabled and part1 then
            local velocityObj = Instance.new("BodyVelocity", part1)
            model:GetPropertyChangedSignal("Parent"):Connect(function()
                if not model.Parent then
                    if isThrowInput() then
                        velocityObj.MaxForce = Vector3.one * math.huge
                        velocityObj.Velocity = Workspace.CurrentCamera.CFrame.LookVector * grabStrength
                        Debris:AddItem(velocityObj, 1)
                    else
                        velocityObj:Destroy()
                    end
                end
            end)
        end
    end)
end)

