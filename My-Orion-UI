function KyoUI:CreateDropdown(parent, config)
    config = config or {}
    
    local frame = Instance.new("Frame")
    frame.Parent = parent
    frame.Size = UDim2.new(1, 0, 0, 40)
    frame.BackgroundTransparency = 1
    
    local label = Instance.new("TextLabel")
    label.Parent = frame
    label.Size = UDim2.new(0.35, 0, 1, 0)
    label.Position = UDim2.new(0, 0, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = config.Name or "Dropdown"
    label.TextColor3 = Colors.Text
    label.TextScaled = true
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    
    local dropdown = Instance.new("TextButton")
    dropdown.Parent = frame
    dropdown.Size = UDim2.new(0.6, 0, 1, 0)
    dropdown.Position = UDim2.new(0.4, 0, 0, 0)
    dropdown.BackgroundColor3 = Colors.Third
    dropdown.Text = config.Default or "Select"
    dropdown.TextColor3 = Colors.Text
    dropdown.TextScaled = true
    dropdown.Font = Enum.Font.Gotham
    dropdown.BorderSizePixel = 0
    CreateCorner(dropdown, 6)
    
    local options = config.Options or {}
    local selected = config.Default or options[1] or "None"
    
    -- ドロップダウンリスト
    local list = Instance.new("ScrollingFrame")
    list.Parent = frame
    list.Size = UDim2.new(0.6, 0, 0, 100)
    list.Position = UDim2.new(0.4, 0, 1, 0)
    list.BackgroundColor3 = Colors.Second
    list.BorderSizePixel = 0
    list.Visible = false
    list.ScrollBarThickness = 3
    list.CanvasSize = UDim2.new(0, 0, 0, 0)
    list.AutomaticCanvasSize = Enum.AutomaticSize.Y
    CreateCorner(list, 6)
    CreateStroke(list, Colors.Accent, 1)
    
    local listLayout = Instance.new("UIListLayout")
    listLayout.Parent = list
    listLayout.Padding = UDim.new(0, 2)
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    
    local function UpdateList()
        -- 既存のアイテムを削除
        for _, child in pairs(list:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
        
        for _, opt in ipairs(options) do
            local btn = Instance.new("TextButton")
            btn.Parent = list
            btn.Size = UDim2.new(1, 0, 0, 30)
            btn.BackgroundColor3 = Colors.Third
            btn.BackgroundTransparency = 0
            btn.Text = opt
            btn.TextColor3 = Colors.Text
            btn.TextScaled = true
            btn.Font = Enum.Font.Gotham
            btn.BorderSizePixel = 0
            
            btn.MouseButton1Click:Connect(function()
                selected = opt
                dropdown.Text = opt
                list.Visible = false
                if config.Callback then
                    config.Callback(opt)
                end
            end)
        end
    end
    
    UpdateList()
    
    dropdown.MouseButton1Click:Connect(function()
        list.Visible = not list.Visible
        if list.Visible then
            list.Size = UDim2.new(0.6, 0, 0, math.min(#options * 32 + 10, 150))
        end
    end)
    
    return frame
end

