function KyoUI:CreateToggle(parent, config)
    config = config or {}
    
    local frame = Instance.new("Frame")
    frame.Parent = parent
    frame.Size = UDim2.new(1, 0, 0, 35)
    frame.BackgroundTransparency = 1
    
    local label = Instance.new("TextLabel")
    label.Parent = frame
    label.Size = UDim2.new(0.7, 0, 1, 0)
    label.Position = UDim2.new(0, 0, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = config.Name or "Toggle"
    label.TextColor3 = Colors.Text
    label.TextScaled = true
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    
    local toggle = Instance.new("Frame")
    toggle.Parent = frame
    toggle.Size = UDim2.new(0, 50, 0, 28)
    toggle.Position = UDim2.new(1, -55, 0.5, -14)
    toggle.BackgroundColor3 = config.Default and Colors.Green or Colors.Red
    toggle.BorderSizePixel = 0
    CreateCorner(toggle, 14)
    
    local indicator = Instance.new("Frame")
    indicator.Parent = toggle
    indicator.Size = UDim2.new(0, 22, 0, 22)
    indicator.Position = config.Default and UDim2.new(1, -26, 0.5, -11) or UDim2.new(0, 4, 0.5, -11)
    indicator.BackgroundColor3 = Colors.Text
    indicator.BorderSizePixel = 0
    CreateCorner(indicator, 11)
    
    local state = config.Default or false
    
    local function UpdateToggle()
        toggle.BackgroundColor3 = state and Colors.Green or Colors.Red
        local pos = state and UDim2.new(1, -26, 0.5, -11) or UDim2.new(0, 4, 0.5, -11)
        Tween(indicator, {Position = pos}, 0.25)
    end
    
    local btn = Instance.new("TextButton")
    btn.Parent = toggle
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.BorderSizePixel = 0
    
    btn.MouseButton1Click:Connect(function()
        state = not state
        UpdateToggle()
        if config.Callback then
            config.Callback(state)
        end
    end)
    
    -- ホバーエフェクト
    local hoverFrame = Instance.new("Frame")
    hoverFrame.Parent = frame
    hoverFrame.Size = UDim2.new(1, 0, 1, 0)
    hoverFrame.BackgroundColor3 = Colors.Text
    hoverFrame.BackgroundTransparency = 0.95
    hoverFrame.BorderSizePixel = 0
    CreateCorner(hoverFrame, 8)
    hoverFrame.Visible = false
    
    frame.MouseEnter:Connect(function()
        hoverFrame.Visible = true
    end)
    frame.MouseLeave:Connect(function()
        hoverFrame.Visible = false
    end)
    
    return frame
end

-- スライダー
function KyoUI:CreateSlider(parent, config)
    config = config or {}
    
    local frame = Instance.new("Frame")
    frame.Parent = parent
    frame.Size = UDim2.new(1, 0, 0, 55)
    frame.BackgroundTransparency = 1
    
    local label = Instance.new("TextLabel")
    label.Parent = frame
    label.Size = UDim2.new(0.8, 0, 0, 20)
    label.Position = UDim2.new(0, 0, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = (config.Name or "Slider") .. ": " .. (config.Default or 0)
    label.TextColor3 = Colors.Text
    label.TextScaled = true
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    
    local slider = Instance.new("Frame")
    slider.Parent = frame
    slider.Size = UDim2.new(1, 0, 0, 6)
    slider.Position = UDim2.new(0, 0, 0, 28)
    slider.BackgroundColor3 = Colors.Third
    slider.BorderSizePixel = 0
    CreateCorner(slider, 3)
    
    local fill = Instance.new("Frame")
    fill.Parent = slider
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = Colors.Accent
    fill.BorderSizePixel = 0
    CreateCorner(fill, 3)
    
    local drag = Instance.new("Frame")
    drag.Parent = slider
    drag.Size = UDim2.new(0, 16, 0, 16)
    drag.Position = UDim2.new(0, -8, 0.5, -8)
    drag.BackgroundColor3 = Colors.Accent2
    drag.BorderSizePixel = 0
    CreateCorner(drag, 8)
    
    local min = config.Min or 0
    local max = config.Max or 100
    local value = config.Default or 50
    local step = config.Increment or 1
    
    local function UpdateSlider(val)
        val = math.clamp(val, min, max)
        val = math.floor(val / step + 0.5) * step
        value = val
        local percent = (val - min) / (max - min)
        fill.Size = UDim2.new(percent, 0, 1, 0)
        drag.Position = UDim2.new(percent, -8, 0.5, -8)
        label.Text = (config.Name or "Slider") .. ": " .. val
        if config.Callback then
            config.Callback(val)
        end
    end
    
    UpdateSlider(value)
    
    -- ドラッグ機能
    local dragging = false
    drag.MouseButton1Down:Connect(function()
        dragging = true
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local pos = input.Position
            local absPos = slider.AbsolutePosition
            local size = slider.AbsoluteSize
            local percent = math.clamp((pos.X - absPos.X) / size.X, 0, 1)
            local val = min + (max - min) * percent
            UpdateSlider(val)
        end
    end)
    
    return frame
end

