function KyoUI:CreateTab(config)
    local self = this or KyoUI
    config = config or {}
    
    local tab = {
        Name = config.Name or "Tab",
        Icon = config.Icon or "rbxassetid://4483345998",
        Elements = {},
        Frame = nil,
        Button = nil,
    }
    
    -- タブボタン
    local btn = Instance.new("TextButton")
    btn.Parent = self.TabList
    btn.Size = UDim2.new(0, 100, 1, -6)
    btn.Position = UDim2.new(0, 0, 0, 3)
    btn.BackgroundColor3 = Colors.Third
    btn.BackgroundTransparency = 0
    btn.Text = "  " .. config.Name
    btn.TextColor3 = Colors.TextDark
    btn.TextScaled = true
    btn.Font = Enum.Font.GothamBold
    btn.BorderSizePixel = 0
    CreateCorner(btn, 6)
    
    -- アイコン
    if config.Icon then
        local icon = Instance.new("ImageLabel")
        icon.Parent = btn
        icon.Size = UDim2.new(0, 20, 0, 20)
        icon.Position = UDim2.new(0, 5, 0.5, -10)
        icon.BackgroundTransparency = 1
        icon.Image = config.Icon
    end
    
    tab.Button = btn
    
    -- タブコンテンツフレーム
    local frame = Instance.new("Frame")
    frame.Parent = self.Scroll
    frame.Size = UDim2.new(1, 0, 0, 0)
    frame.BackgroundTransparency = 1
    frame.Visible = false
    frame.AutomaticSize = Enum.AutomaticSize.Y
    
    local layout = Instance.new("UIListLayout")
    layout.Parent = frame
    layout.Padding = UDim.new(0, 8)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    
    tab.Frame = frame
    
    -- タブ切り替え
    btn.MouseButton1Click:Connect(function()
        self:SelectTab(tab)
    end)
    
    table.insert(self.Tabs, tab)
    
    -- 最初のタブを選択
    if #self.Tabs == 1 then
        self:SelectTab(tab)
    end
    
    return tab
end

function KyoUI:SelectTab(tab)
    local self = this or KyoUI
    
    -- 全てのタブを非表示
    for _, t in ipairs(self.Tabs) do
        t.Frame.Visible = false
        t.Button.BackgroundColor3 = Colors.Third
        t.Button.TextColor3 = Colors.TextDark
    end
    
    -- 選択したタブを表示
    tab.Frame.Visible = true
    tab.Button.BackgroundColor3 = Colors.Accent
    tab.Button.TextColor3 = Colors.Text
    
    self.CurrentTab = tab
end

