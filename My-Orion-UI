    notification.BackgroundColor3 = Colors.Second
    notification.BackgroundTransparency = 0.1
    notification.BorderSizePixel = 0
    CreateCorner(notification, 10)
    CreateStroke(notification, Colors.Accent, 2)
    
    -- アニメーションで表示
    notification.Position = UDim2.new(1, 20, 0, 20)
    notification.BackgroundTransparency = 1
    
    local title = Instance.new("TextLabel")
    title.Parent = notification
    title.Size = UDim2.new(1, -10, 0.4, 0)
    title.Position = UDim2.new(0, 5, 0, 2)
    title.BackgroundTransparency = 1
    title.Text = config.Name or "Notification"
    title.TextColor3 = Colors.Accent
    title.TextScaled = true
    title.Font = Enum.Font.GothamBold
    title.TextXAlignment = Enum.TextXAlignment.Left
    
    local content = Instance.new("TextLabel")
    content.Parent = notification
    content.Size = UDim2.new(1, -10, 0.5, 0)
    content.Position = UDim2.new(0, 5, 0, 25)
    content.BackgroundTransparency = 1
    content.Text = config.Content or ""
    content.TextColor3 = Colors.Text
    content.TextScaled = true
    content.Font = Enum.Font.Gotham
    content.TextXAlignment = Enum.TextXAlignment.Left
    
    -- スライドイン
    task.spawn(function()
        notification.Position = UDim2.new(1, 20, 0, 20)
        Tween(notification, {Position = UDim2.new(1, -320, 0, 20), BackgroundTransparency = 0.1}, 0.5)
        
        task.wait(config.Time or 3)
        
        Tween(notification, {Position = UDim2.new(1, 20, 0, 20), BackgroundTransparency = 1}, 0.5)
        task.wait(0.5)
        notification:Destroy()
    end)
end

-- ============================================
-- 破棄関数
-- ============================================

function KyoUI:Destroy()
    if self.ScreenGui then
        self.ScreenGui:Destroy()
    end
end

-- ============================================
-- グローバル公開
-- ============================================

return KyoUI
