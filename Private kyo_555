    task.wait(0.25)
    gucciBlobman = gucciGetBlobman()
end

local function gucciEnsureBlobman()
    if not (gucciBlobman and gucciBlobman.Parent) then
        gucciSpawnBlobman()
    end
    return gucciBlobman
end

local function gucciGetPrimary()
    if not gucciBlobman then return end
    local p = gucciBlobman.PrimaryPart or gucciBlobman:FindFirstChildWhichIsA("BasePart")
    if p and not gucciBlobman.PrimaryPart then gucciBlobman.PrimaryPart = p end
    return p
end

local function gucciSeatJumpRagdoll()
    local char = gucciGetChar()
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not (hum and hrp and gucciBlobman) then return end
    local seat = gucciBlobman:FindFirstChildWhichIsA("VehicleSeat")
    if not seat then return end
    gucciLastSeat = seat
    gucciAllowSeat = true
    for i = 1, 400 do
        pcall(function()
            if gucciAllowSeat and seat.Occupant ~= hum then
                seat:Sit(hum)
            end
            if RagdollRemote then
                RagdollRemote:FireServer(hrp, 0)
            end
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
        end)
    end
    gucciAllowSeat = false
end

local function gucciRunAnti(duration)
    local hrp = gucciGetChar():FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local start = tick()
    while gucciAntiRunning and tick() - start < duration do
        if not (gucciBlobman and gucciBlobman.Parent) then break end
        if RagdollRemote then
            RagdollRemote:FireServer(hrp, 0)
        end
        task.wait(0.01)
    end
end

local function gucciYeetUp()
    local p = gucciGetPrimary()
    if not p then return end
    pcall(function()
        SetNetworkOwner:FireServer(p, gucciGetChar().HumanoidRootPart.CFrame)
    end)
    for _, v in ipairs(gucciBlobman:GetDescendants()) do
        if v:IsA("BasePart") then v.CanCollide = false end
    end
    local pos = p.Position
    p.CFrame = CFrame.new(pos.X, pos.Y + 1e8, pos.Z)
end

local function gucciClearAll()
    gucciAllowSeat = false
    if gucciBlobman then
        DestroyToy:FireServer(gucciBlobman)
    end
    gucciBlobman = nil
    gucciLastSeat = nil
end

local function gucciRunOnce()
    gucciAntiRunning = true
    gucciEnsureBlobman()
    if not gucciBlobman then return end
    gucciSeatJumpRagdoll()
    gucciRunAnti(GUCCI_ANTI_DURATION)
    gucciYeetUp()
    task.delay(0.5, function()
        if gucciLastSeat and gucciLastSeat.Parent then
            gucciLastSeat:Destroy()
        end
    end)
end

