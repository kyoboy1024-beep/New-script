local grabFlags = {
    KillGrab = false,
    SkyGrab = false,
    SpinGrab = false,
    FreezeGrab = false,
    FlingGrab = false,
    VoidGrab = false,
    PoisonGrab = false,
    RagdollGrab = false,
    FireGrab = false,
    NoclipGrab = false,
    KickGrab = false,
    StrengthEnabled = false,
}

local grabStrength = 500
local poisonHurtParts = {}
local noclipGrabCo = nil
local kickGrabConnections = {}

local function getPoisonParts()
    local parts = {}
    pcall(function()
        local map = Workspace:FindFirstChild("Map")
        if map then
            for _, d in ipairs(map:GetDescendants()) do
                if d:IsA("Part") and d.Name == "PoisonHurtPart" then
                    table.insert(parts, d)
                end
            end
        end
    end)
    return parts
end

local function updatePoisonParts()
    poisonHurtParts = getPoisonParts()
end
updatePoisonParts()

local function setNetworkOwner(part)
    pcall(function()
        local root = getRoot()
        if root then
            ReplicatedStorage.GrabEvents.SetNetworkOwner:FireServer(part, root.CFrame)
        end
    end)
end

local function applyVelocity(part, vec)
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.one * math.huge
    bv.Velocity = vec
    bv.Parent = part
    Debris:AddItem(bv, 1)
end

local function applyFire(part)
    pcall(function()
        local inv = Workspace:FindFirstChild(LP.Name .. "SpawnedInToys")
        if not inv:FindFirstChild("Campfire") then
            ReplicatedStorage.MenuToys.SpawnToyRemoteFunction:InvokeServer(
                "Campfire",
                CFrame.new(part.Position),
                Vector3.new(0, 0, 0)
            )
        end
        local campfire = inv:WaitForChild("Campfire", 5)
        if campfire then
            local firePart = campfire:FindFirstChild("FirePlayerPart")
            if firePart then
                firePart.Size = Vector3.new(7, 7, 7)
                firePart.Position = part.Position
                task.wait(0.3)
                firePart.Position = Vector3.new(0, -50, 0)
            end
        end
    end)
end

local function noclipGrabLoopFunc()
    while true do
        pcall(function()
            local grabParts = Workspace:FindFirstChild("GrabParts")
            if grabParts then
                local grabPart = grabParts:FindFirstChild("GrabPart")
                if grabPart and grabPart:FindFirstChild("WeldConstraint") then
                    local weld = grabPart.WeldConstraint
                    local part1 = weld.Part1
                    if part1 then
                        local char = part1.Parent
                        if char and char:FindFirstChild("HumanoidRootPart") then
                            while Workspace:FindFirstChild("GrabParts") do
                                for _, p in pairs(char:GetDescendants()) do
                                    if p:IsA("BasePart") then
                                        p.CanCollide = false
                                    end
                                end
                                task.wait()
                            end
                            for _, p in pairs(char:GetDescendants()) do
                                if p:IsA("BasePart") then
                                    p.CanCollide = true
                                end
                            end
                        end
                    end
                end
            end
        end)
        task.wait()
    end
end

local strengthLastThrow = false

local function isThrowInput()
    local UIS = UserInputService
    if UIS.TouchEnabled then
        return strengthLastThrow
    else
        return UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
    end
end

UserInputService.TouchEnded:Connect(function(touch, _)
    local screenSize = Workspace.CurrentCamera.ViewportSize
    if touch.Position.X > screenSize.X * 0.5 then
        strengthLastThrow = true
        task.delay(0.3, function() strengthLastThrow = false end)
    end
end)

local function handleCharacterKickGrab(player)
    local conn = player.CharacterAdded:Connect(function(character)
        local hrp = character:WaitForChild("HumanoidRootPart")
        local fpp = hrp:WaitForChild("FirePlayerPart", 5)
        if fpp then
            fpp.Size = Vector3.new(4.5, 5, 4.5)
            fpp.CollisionGroup = "1"
            fpp.CanQuery = true
        end
    end)
    table.insert(kickGrabConnections, conn)
end

local function enableKickGrab()
    for _, player in pairs(Players:GetPlayers()) do
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = player.Character.HumanoidRootPart
            local fpp = hrp:FindFirstChild("FirePlayerPart")
            if fpp then
                fpp.Size = Vector3.new(4.5, 5.5, 4.5)
                fpp.CollisionGroup = "1"
                fpp.CanQuery = true
            end
        end
        handleCharacterKickGrab(player)
    end
    local paConn = Players.PlayerAdded:Connect(handleCharacterKickGrab)
    table.insert(kickGrabConnections, paConn)
end

local function disableKickGrab()
    for _, conn in pairs(kickGrabConnections) do
        conn:Disconnect()
    end
    kickGrabConnections = {}
    for _, player in pairs(Players:GetPlayers()) do
        pcall(function()
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            local fpp = hrp and hrp:FindFirstChild("FirePlayerPart")
            if fpp then
                fpp.Size = Vector3.new(2.5, 5.5, 2.5)
                fpp.CollisionGroup = "Default"
                fpp.CanQuery = false
            end
        end)
    end
end

Workspace.ChildAdded:Connect(function(model)
    if model.Name ~= "GrabParts" then return end
    
    task.spawn(function()
        local grabPart = model:WaitForChild("GrabPart", 1)
        if not grabPart then return end
        task.wait()
        
        local weld = grabPart:FindFirstChild("WeldConstraint")
        local part1 = weld and weld.Part1
        
        if not part1 then
            task.wait()
            weld = grabPart:FindFirstChild("WeldConstraint")
            part1 = weld and weld.Part1
        end
        
        if part1 and LP.Character and part1:IsDescendantOf(LP.Character) then return end
        if grabPart and LP.Character and grabPart:IsDescendantOf(LP.Character) then return end
        if model and LP.Character and model:IsDescendantOf(LP.Character) then return end
        
        if grabFlags.KillGrab and part1 then
            pcall(function() part1.Parent:BreakJoints() end)
        end
        
        if grabFlags.SkyGrab and part1 then
            local bv = Instance.new("BodyVelocity", part1)
            bv.Velocity = Vector3.new(0, 100, 0)
            bv.MaxForce = Vector3.new(0, math.huge, 0)
            Debris:AddItem(bv, 1.5)
        end
        
        if grabFlags.SpinGrab and part1 then
            pcall(function()
                local bav = Instance.new("BodyAngularVelocity", part1)
                bav.AngularVelocity = Vector3.new(0, 1000, 0)
                bav.MaxTorque = Vector3.one * math.huge
            end)
        end
        
        if grabFlags.FreezeGrab and part1 then
            for _, child in ipairs(model:GetDescendants()) do
                if child:IsA("BasePart") then
                    child.Anchored = true
                end
            end
        end
        
        if grabFlags.FlingGrab and part1 then
            pcall(function()
                setNetworkOwner(part1)
                applyVelocity(part1, Vector3.new(math.random(-100, 100), 200, math.random(-100, 100)))
            end)
        end
        
        if grabFlags.VoidGrab and part1 then
            pcall(function()
                setNetworkOwner(part1)
                applyVelocity(part1, Vector3.new(0, -500, 0))
            end)
        end
        
        if grabFlags.PoisonGrab and part1 then
            pcall(function()
                local head = part1.Parent:FindFirstChild("Head")
                if head and #poisonHurtParts > 0 then
                    updatePoisonParts()
                    while Workspace:FindFirstChild("GrabParts") do
                        for _, p in pairs(poisonHurtParts) do
                            p.Size = Vector3.new(2, 2, 2)
                            p.Transparency = 1
                            p.Position = head.Position
                        end
                        task.wait()
                        for _, p in pairs(poisonHurtParts) do
                            p.Position = Vector3.new(0, -200, 0)
                        end
                    end
                end
            end)
        end
        
        if grabFlags.RagdollGrab and part1 then
            local ragdollRemote = ReplicatedStorage.CharacterEvents:FindFirstChild("RagdollRemote")
            if ragdollRemote then
                pcall(function() ragdollRemote:FireServer(part1, 999999) end)
            end
        end
        
        if grabFlags.FireGrab and part1 then
            pcall(function()
                local head = part1.Parent:FindFirstChild("Head")
                if head then applyFire(head) end
            end)
        end
        
        if grabFlags.NoclipGrab then
            if noclipGrabCo and coroutine.status(noclipGrabCo) ~= "dead" then
                coroutine.close(noclipGrabCo)
            end
            noclipGrabCo = coroutine.create(noclipGrabLoopFunc)
            coroutine.resume(noclipGrabCo)
        end
        
        if grabFlags.KickGrab then
            enableKickGrab()
        elseif not grabFlags.KickGrab and #kickGrabConnections > 0 then
            disableKickGrab()
        end
        
        if grabFlags.StrengthEnabled and part1 then
            local velocityObj = Instance.new("BodyVelocity", part1)
            model:GetPropertyChangedSignal("Parent"):Connect(function()
                if not model.Parent then
                    if isThrowInput() then
                        velocityObj.MaxForce = Vector3.one * math.huge
                        velocityObj.Velocity = Workspace.CurrentCamera.CFrame.LookVector * grabStrength
                        Debris:AddItem(velocityObj, 1)
                    else
                        velocityObj:Destroy()
                    end
                end
            end)
        end
    end)
end)

