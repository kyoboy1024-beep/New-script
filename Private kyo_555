-- 列車コントロールのメインループ
RunService.RenderStepped:Connect(function()
    local hum = TrainControlFeature.getHum()
    if not hum then
        if TrainSettings.Enabled or TrainSettings.VFlyEnabled or TrainSettings.Running or TrainSettings.NoClip then
            TrainControlFeature.hardStopAll()
        end
        return
    end

    local seatPart = hum.SeatPart

    if TrainSettings.Enabled then
        if TrainSettings.HadSeatOnce and not seatPart then
            if TrainSettings.VFlyEnabled then
                TrainControlFeature.destroyVFly()
            end
            if tick() - TrainSettings.LastSitAttempt >= TrainSettings.SitRetryInterval then
                TrainSettings.LastSitAttempt = tick()
                for i = 1, 3 do
                    TrainControlFeature.sitTrain()
                    task.wait(0.005)
                end
            end
            return
        end

        if not seatPart then
            if tick() - TrainSettings.TrainEnableAt <= TrainSettings.SeatGraceSeconds then
                if tick() - TrainSettings.LastSitAttempt >= TrainSettings.SitRetryInterval then
                    TrainSettings.LastSitAttempt = tick()
                    for i = 1, 3 do
                        TrainControlFeature.sitTrain()
                        task.wait(0.005)
                    end
                end
                return
            else
                TrainControlFeature.hardStopAll()
                return
            end
        end

        if not TrainControlFeature.isTrainSeat(seatPart) then
            if tick() - TrainSettings.TrainEnableAt <= TrainSettings.SeatGraceSeconds then
                if tick() - TrainSettings.LastSitAttempt >= TrainSettings.SitRetryInterval then
                    TrainSettings.LastSitAttempt = tick()
                    for i = 1, 3 do
                        TrainControlFeature.sitTrain()
                        task.wait(0.005)
                    end
                end
                return
            else
                TrainControlFeature.hardStopAll()
                return
            end
        end

        local justMounted = false
        if not TrainSettings.HadSeatOnce then
            justMounted = true
        end

        TrainSettings.HadSeatOnce = true
        TrainControlFeature.enableCameraNoClip()

        if justMounted then
            TrainControlFeature.forceSpawnToyAtHRP()
        end

        if TrainSettings.NoClip then
            local trainModel = TrainControlFeature.getTrainModel()
            if trainModel then
                if TrainSettings.NoClipVehicleModel ~= trainModel then
                    TrainControlFeature.restoreVehicleNoClip()
                    TrainSettings.NoClipVehicleModel = trainModel
                end
                TrainControlFeature.applyNoClipToModel(trainModel, TrainSettings.NoClipVehicleState)
            end

            local cModel = LP.Character
            if cModel then
                if TrainSettings.NoClipCharModel ~= cModel then
                    TrainControlFeature.restoreCharNoClip()
                    TrainSettings.NoClipCharModel = cModel
                end
                TrainControlFeature.applyNoClipToModel(cModel, TrainSettings.NoClipCharState)
            end
        else
            if TrainSettings.NoClipVehicleModel then TrainControlFeature.restoreVehicleNoClip() end
            if TrainSettings.NoClipCharModel then TrainControlFeature.restoreCharNoClip() end
        end

        if not TrainSettings.VFlyEnabled then
            TrainControlFeature.startVFlyForTrain()
        end
        
        if TrainSettings.VFlyEnabled and TrainSettings.TargetPart and tick() - TrainSettings.LastNetworkOwnership > TrainSettings.NetworkOwnershipInterval then
            TrainControlFeature.claimNetworkOwnership(TrainSettings.TargetPart)
            TrainSettings.LastNetworkOwnership = tick()
        end
    else
        if TrainSettings.VFlyEnabled or TrainSettings.Running or TrainSettings.NoClip then
            TrainControlFeature.hardStopAll()
        end
    end

    if not TrainSettings.VFlyEnabled then return end
    if not (TrainSettings.TargetPart and TrainSettings.TargetPart.Parent and TrainSettings.BV and TrainSettings.BG) then
        TrainControlFeature.hardStopAll()
        return
    end

    local cam = Workspace.CurrentCamera
    if not cam then return end

    local move = TrainControlFeature.getMoveVector()
    local dir = Vector3.zero

    if move.Magnitude > 0 then
        dir = cam.CFrame.RightVector * move.X + cam.CFrame.LookVector * (-move.Z)
        if dir.Magnitude > 0 then dir = dir.Unit end
    end

    local speed = TrainSettings.FlySpeed * TrainSettings.SPEED_MULT
    TrainSettings.BV.Velocity = dir * speed
    TrainSettings.BG.CFrame = CFrame.lookAt(TrainSettings.TargetPart.Position, TrainSettings.TargetPart.Position + cam.CFrame.LookVector, cam.CFrame.UpVector)
end)

