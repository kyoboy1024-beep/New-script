function ToyModFeature.GetToys()
    local toys = {}
    local playerName = LP.Name

    local spawned = Workspace:FindFirstChild(playerName .. "SpawnedInToys")
    if spawned then
        for _, toy in pairs(spawned:GetChildren()) do
            if toy.Name ~= "ToyNumber" then
                table.insert(toys, toy)
            end
        end
    end

    if #toys == 0 then
        local toysFolder = Workspace:FindFirstChild("Toys")
        if toysFolder then
            for _, toy in pairs(toysFolder:GetChildren()) do
                if toy:IsA("Model") or toy:IsA("BasePart") then
                    table.insert(toys, toy)
                end
            end
        end
    end

    if #toys == 0 then
        for _, obj in pairs(Workspace:GetChildren()) do
            if obj:IsA("Model") and obj ~= LP.Character then
                local isPart = obj:FindFirstChildWhichIsA("BasePart")
                if isPart and obj.Name ~= "Baseplate" and obj.Name ~= "Terrain" then
                    local size = obj:GetExtentsSize()
                    if size.Magnitude > 0.5 and size.Magnitude < 50 then
                        table.insert(toys, obj)
                    end
                end
            end
        end
    end

    if ToySettings.UsePlotItems then
        local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return toys end

        local playerPos = hrp.Position
        local myPlot = nil

        for _, plotInfo in ipairs(Plots) do
            local distXZ = (Vector2.new(playerPos.X, playerPos.Z) - Vector2.new(plotInfo.Center.X, plotInfo.Center.Z)).Magnitude
            if distXZ <= plotInfo.Radius then
                myPlot = plotInfo
                break
            end
        end

        if myPlot then
            local plotItems = Workspace:FindFirstChild("PlotItems")
            if plotItems then
                local plotFolder = plotItems:FindFirstChild(myPlot.Name)
                if plotFolder then
                    for _, obj in pairs(plotFolder:GetDescendants()) do
                        if (obj:IsA("BasePart") or obj:IsA("Model")) and obj.Name ~= "ToysLimitNum" then
                            local size = obj:IsA("BasePart") and obj.Size or (obj:IsA("Model") and obj:GetExtentsSize())
                            if size and size.Magnitude > 1 and size.Magnitude < 20 then
                                table.insert(toys, obj)
                            end
                        end
                    end
                end
            end
        end
    end

    return toys
end

function ToyModFeature.CreateWings()
    if ToyState.Connection then 
        ToyState.Connection:Disconnect() 
        ToyState.Connection = nil 
    end
    
    for _, v in pairs(ToyState.BodyPositions) do 
        if v and v.Parent then v:Destroy() end 
    end
    
    for _, v in pairs(ToyState.AlignOrientations) do 
        if v and v.Parent then v:Destroy() end 
    end
    
    ToyState.Parts = {}
    ToyState.BodyPositions = {}
    ToyState.AlignOrientations = {}
    ToyState.OriginalAnchored = {}
    ToyState.FlapTime = 0
    ToyState.TargetCFrames = {}

    local toys = ToyModFeature.GetToys()
    OrionLib:MakeNotification({
        Name = "ToyMod",
        Content = "Found " .. #toys .. " toys",
        Time = 2
    })
    
    if #toys == 0 then 
        OrionLib:MakeNotification({
            Name = "Error",
            Content = "No toys found! Please select toys first",
            Time = 3
        })
        return 
    end

    for i = 1, #toys do
        local toy = toys[i]
        local part = toy:IsA("BasePart") and toy or toy:FindFirstChildWhichIsA("BasePart")
        if not part then continue end

        local partsToProcess = toy:IsA("Model") and toy:GetDescendants() or {part}
        for _, p in pairs(partsToProcess) do
            if p:IsA("BasePart") then
                table.insert(ToyState.OriginalAnchored, {Part = p, Anchored = p.Anchored})
                if p.Anchored then
                    p.Anchored = false
                end
                p.CanCollide = false
            end
        end

        local bp = Instance.new("BodyPosition")
        bp.MaxForce = Vector3.new(5e6, 5e6, 5e6)
        bp.P = 15000
        bp.D = 200
        bp.Position = part.Position
        bp.Parent = part
        table.insert(ToyState.BodyPositions, bp)

        local ao = Instance.new("AlignOrientation")
        ao.MaxTorque = 400000
        ao.Responsiveness = 2000
        ao.Mode = Enum.OrientationAlignmentMode.OneAttachment
        ao.Parent = part
        local att = Instance.new("Attachment", part)
        ao.Attachment0 = att
        table.insert(ToyState.AlignOrientations, ao)
        table.insert(ToyState.Parts, part)
        table.insert(ToyState.TargetCFrames, part.CFrame)
    end

    ToyState.Connection = RunService.Heartbeat:Connect(function()
        local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local root = hrp.CFrame

        local currentPos = hrp.Position
        local playerVelocity = hrp.AssemblyLinearVelocity.Magnitude
        
        if not ToyState.LastPos then
            ToyState.LastPos = currentPos
        end
        
        local cframeVelocity = (currentPos - ToyState.LastPos).Magnitude / (1 / 60)
        ToyState.LastPos = currentPos
        
        playerVelocity = math.max(playerVelocity, cframeVelocity)
        
        local speedMultiplier = 1
        if ToySettings.SpeedLinkFlap then
            speedMultiplier = 0.7 + (playerVelocity / 20)
        end

        if ToySettings.FlapEnabled then
            ToyState.FlapTime = ToyState.FlapTime + ToySettings.FlapSpeed * speedMultiplier * 0.016
        end

        local total = #ToyState.Parts
        local center = (total + 1) / 2

        for i, part in ipairs(ToyState.Parts) do
            local offsetFromCenter = i - center
            local side = math.sign(offsetFromCenter)
            local dist = math.abs(offsetFromCenter)

            local xOff = side * (dist + 0.5) * ToySettings.XSpacing

            local flap = 0
            local yMove = 0
            local zRot = 0

            if ToySettings.FlapEnabled then
                local time = ToyState.FlapTime
                local mul = (dist + 1) / (math.max(center, 1) + 0.5)

                local phaseOffset = dist * 0.08

                if ToySettings.FlapType == 1 then
                    flap = math.sin(time + phaseOffset)
                    yMove = flap * (ToySettings.FlapRange * 0.2) * mul
                    zRot = flap * ToySettings.FlapRange * mul

                elseif ToySettings.FlapType == 2 then
                    flap = math.sin(time + phaseOffset * 1.5) * 0.8 + math.sin(time * 0.5 + phaseOffset * 0.8) * 0.2
                    yMove = flap * (ToySettings.FlapRange * 0.15) * mul
                    zRot = math.sin(time * 1.2 + phaseOffset * 1.2) * ToySettings.FlapRange * 0.7 * mul

                elseif ToySettings.FlapType == 3 then
                    flap = math.sin(time * 0.5 + phaseOffset * 0.4) * 0.6 + math.sin(time * 0.3 + phaseOffset * 0.6) * 0.4
                    yMove = flap * (ToySettings.FlapRange * 0.3) * mul
                    zRot = math.sin(time * 0.8 + phaseOffset * 0.5) * (ToySettings.FlapRange * 0.3) * mul

                elseif ToySettings.FlapType == 4 then
                    flap = math.sin(time * 2 + phaseOffset * 2) * 0.7
                    yMove = flap * (ToySettings.FlapRange * 0.25) * mul
                    zRot = math.sin(time * 2.5 + phaseOffset * 2.2) * ToySettings.FlapRange * 0.8 * mul

                elseif ToySettings.FlapType == 5 then
                    flap = math.sin(time * 0.8 + phaseOffset) * 0.6
                    yMove = flap * (ToySettings.FlapRange * 0.3) * mul
                    zRot = (time * 80 + dist * 30) % 360

                elseif ToySettings.FlapType == 6 then
                    flap = math.sin(time * 0.3 + phaseOffset * 3) * 0.9
                    yMove = (flap + 0.5) * (ToySettings.FlapRange * 0.2) * mul
                    zRot = math.sin(time * 0.4 + phaseOffset * 1.5) * ToySettings.FlapRange * 0.6 * mul

                elseif ToySettings.FlapType == 7 then
                    flap = math.cos(time * 1.5 + phaseOffset * 1.5) * 0.8
                    yMove = math.sin(time * 0.6 + phaseOffset) * (ToySettings.FlapRange * 0.15) * mul
                    zRot = flap * ToySettings.FlapRange * 1.2 * mul

                elseif ToySettings.FlapType == 8 then
                    local pulse = math.floor(time * 2 + phaseOffset) % 2
                    flap = pulse == 0 and 1 or -1
                    yMove = flap * (ToySettings.FlapRange * 0.2) * mul
                    zRot = flap * ToySettings.FlapRange * 0.7 * mul

                elseif ToySettings.FlapType == 9 then
                    local cycleFrac = ((time + phaseOffset) % 4) / 4
                    if cycleFrac < 0.3 then
                        yMove = (0.3 - cycleFrac) / 0.3 * ToySettings.FlapRange * 0.4 * mul
                    else
                        yMove = -((cycleFrac - 0.3) / 0.7) * ToySettings.FlapRange * 0.4 * mul
                    end
                    zRot = math.sin(time * 1.5 + phaseOffset) * ToySettings.FlapRange * 0.5 * mul

                elseif ToySettings.FlapType == 10 then
                    flap = math.sin(time * 0.7 + phaseOffset * 4) * 0.8
                    yMove = math.sin(time * 0.5 + phaseOffset * 2) * (ToySettings.FlapRange * 0.25) * mul
                    zRot = (math.sin(time * 1.1 + phaseOffset * 3) + math.sin(time * 0.5 + phaseOffset * 1)) * ToySettings.FlapRange * 0.5 * mul

                elseif ToySettings.FlapType == 11 then
                    local waveA = math.sin(time * 0.6 + phaseOffset * 0.6) * 0.7
                    local waveB = math.sin(time * 0.3 + dist * 0.5) * 0.3
                    yMove = (waveA + waveB) * (ToySettings.FlapRange * 0.35) * mul
                    zRot = (waveA * 1.2 + waveB * 0.5) * ToySettings.FlapRange * mul

                elseif ToySettings.FlapType == 12 then
                    local rot = time * 120 + dist * 40
                    zRot = rot % 360
                    yMove = math.sin(time * 1.5 + phaseOffset * 1.5) * (ToySettings.FlapRange * 0.25) * mul
                end
            end

            local appliedAngleH = ToySettings.AngleH

            local targetCFrame = root
                * CFrame.new(xOff, ToySettings.YOffset + yMove, ToySettings.ZOffset)
                * CFrame.Angles(
                    math.rad(ToySettings.AngleV),
                    math.rad(appliedAngleH),
                    math.rad(zRot)
                )

            ToyState.TargetCFrames[i] = targetCFrame
            ToyState.BodyPositions[i].Position = targetCFrame.Position
            ToyState.AlignOrientations[i].CFrame = targetCFrame
        end
    end)
    
    OrionLib:MakeNotification({
        Name = "ToyMod",
        Content = "Wings created!",
        Time = 2
    })
end

function ToyModFeature.DestroyWings()
    if ToyState.Connection then 
        ToyState.Connection:Disconnect() 
        ToyState.Connection = nil 
    end
    
    for _, v in pairs(ToyState.BodyPositions) do 
        if v and v.Parent then v:Destroy() end 
    end
    
    for _, v in pairs(ToyState.AlignOrientations) do 
        if v and v.Parent then v:Destroy() end 
    end
    
    for _, info in pairs(ToyState.OriginalAnchored) do
        if info.Part and info.Part.Parent then
            info.Part.Anchored = info.Anchored
        end
    end

    ToyState.Parts = {}
    ToyState.BodyPositions = {}
    ToyState.AlignOrientations = {}
    ToyState.OriginalAnchored = {}
    ToyState.FlapTime = 0
    ToyState.TargetCFrames = {}
    
    OrionLib:MakeNotification({
        Name = "ToyMod",
        Content = "Wings destroyed!",
        Time = 2
    })
end

