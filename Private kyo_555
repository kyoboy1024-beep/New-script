local TrainControlFeature = {}

-- 設定変数
local TrainSettings = {
    Enabled = false,
    FlySpeed = 15,
    NoClip = false,
    ToyName = "FoodHamburger",
    Interval = 0.01,
    HeadOffset = Vector3.new(0, 3, 0),
    SpawnTimeout = 0.1,
    SPEED_MULT = 25,
    BV_P = 25000,
    BG_P = 6000,
    SeatGraceSeconds = 2.5,
    SitRetryInterval = 0.01,
    NetworkOwnershipInterval = 0.005,
    ParallelOwnershipThreads = 5,
    Running = false,
    TrainEnableAt = 0,
    LastSitAttempt = 0,
    HadSeatOnce = false,
    LoopThread = nil,
    VFlyEnabled = false,
    TargetPart = nil,
    BV = nil,
    BG = nil,
    LastNetworkOwnership = 0,
    OwnershipThreads = {},
    NoClipVehicleModel = nil,
    NoClipCharModel = nil,
    NoClipVehicleState = {},
    NoClipCharState = {},
    prevOcclusionMode = nil,
}

-- プレイヤースクリプトからControlModuleを取得
local PM = LP:WaitForChild("PlayerScripts"):WaitForChild("PlayerModule")
local CM = require(PM:WaitForChild("ControlModule"))

-- 基本関数
function TrainControlFeature.getMoveVector()
    return CM:GetMoveVector()
end

function TrainControlFeature.getToyFolder()
    return Workspace:FindFirstChild(LP.Name .. "SpawnedInToys")
end

function TrainControlFeature.getToyInFolder()
    local folder = TrainControlFeature.getToyFolder()
    if folder then
        return folder:FindFirstChild(TrainSettings.ToyName)
    end
    return nil
end

function TrainControlFeature.spawnToy(targetCFrame)
    local menu = ReplicatedStorage:FindFirstChild("MenuToys")
    local spawnRF = menu and menu:FindFirstChild("SpawnToyRemoteFunction")
    if not spawnRF then return nil end
    local ok = pcall(function()
        spawnRF:InvokeServer(TrainSettings.ToyName, targetCFrame, Vector3.new(0, 0, 0))
    end)
    if not ok then return nil end
    local start = tick()
    while tick() - start < TrainSettings.SpawnTimeout do
        local toy = TrainControlFeature.getToyInFolder()
        if toy then return toy end
        task.wait(0.01)
    end
    return nil
end

function TrainControlFeature.getHRP()
    local char = LP.Character
    return char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
end

function TrainControlFeature.forceSpawnToyAtHRP()
    local hrp = TrainControlFeature.getHRP()
    if not hrp then return nil end
    local folder = TrainControlFeature.getToyFolder()
    if folder then
        local old = folder:FindFirstChild(TrainSettings.ToyName)
        if old then
            pcall(function() old:Destroy() end)
        end
    end
    return TrainControlFeature.spawnToy(hrp.CFrame * CFrame.new(TrainSettings.HeadOffset))
end

function TrainControlFeature.ensureToy()
    local toy = TrainControlFeature.getToyInFolder()
    if toy and toy.Parent then return toy end
    return TrainControlFeature.forceSpawnToyAtHRP()
end

-- 列車の全座席を取得
function TrainControlFeature.getAllTrainSeats()
    local seats = {}
    local map = Workspace:FindFirstChild("Map")
    local ahto = map and map:FindFirstChild("AlwaysHereTweenedObjects")
    local train = ahto and ahto:FindFirstChild("Train")
    local obj = train and train:FindFirstChild("Object")
    local objModel = obj and obj:FindFirstChild("ObjectModel")
    
    if objModel then
        for _, descendant in ipairs(objModel:GetDescendants()) do
            if descendant:IsA("Seat") or descendant:IsA("VehicleSeat") then
                table.insert(seats, descendant)
            end
        end
    end
    
    return seats
end

function TrainControlFeature.getFirstTrainSeat()
    local seats = TrainControlFeature.getAllTrainSeats()
    return seats[1]
end

function TrainControlFeature.getTrainModel()
    local map = Workspace:FindFirstChild("Map")
    local ahto = map and map:FindFirstChild("AlwaysHereTweenedObjects")
    local train = ahto and ahto:FindFirstChild("Train")
    local obj = train and train:FindFirstChild("Object")
    return obj and obj:FindFirstChild("ObjectModel")
end

function TrainControlFeature.isTrainSeat(seatPart)
    if not seatPart then return false end
    local trainModel = TrainControlFeature.getTrainModel()
    if not trainModel then return false end
    
    return seatPart:IsDescendantOf(trainModel)
end

function TrainControlFeature.sitTrain()
    local char = LP.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local seat = TrainControlFeature.getFirstTrainSeat()
    if hum and seat then
        pcall(function()
            seat:Sit(hum)
        end)
    end
end

function TrainControlFeature.getHum()
    local c = LP.Character
    return c and c:FindFirstChildOfClass("Humanoid")
end

function TrainControlFeature.enableCameraNoClip()
    if TrainSettings.prevOcclusionMode == nil then
        TrainSettings.prevOcclusionMode = LP.DevCameraOcclusionMode
    end
    LP.DevCameraOcclusionMode = Enum.DevCameraOcclusionMode.Invisicam
end

function TrainControlFeature.restoreCameraNoClip()
    if TrainSettings.prevOcclusionMode ~= nil then
        LP.DevCameraOcclusionMode = TrainSettings.prevOcclusionMode
        TrainSettings.prevOcclusionMode = nil
    end
end

function TrainControlFeature.getAllPlayerEggs()
    local eggs = {}
    for _, player in ipairs(Players:GetPlayers()) do
        local egg = Workspace:FindFirstChild(player.Name)
        if egg then
            table.insert(eggs, egg)
        end
    end
    return eggs
end

function TrainControlFeature.startLoop()
    if TrainSettings.LoopThread then return end
    TrainSettings.LoopThread = task.spawn(function()
        while TrainSettings.Running and not TrainControlFeature.getHRP() do
            task.wait(0.01)
        end
        if not TrainSettings.Running then
            TrainSettings.LoopThread = nil
            return
        end

        while TrainSettings.Running do
            local cycleStart = tick()

            local hrp = TrainControlFeature.getHRP()
            local eggs = TrainControlFeature.getAllPlayerEggs()

            if hrp and #eggs > 0 then
                for _, egg in ipairs(eggs) do
                    local toy = TrainControlFeature.ensureToy()
                    if toy and toy.Parent then
                        local menu = ReplicatedStorage:FindFirstChild("MenuToys")
                        local holdFn = (toy:FindFirstChild("HoldPart") and toy.HoldPart:FindFirstChild("HoldItemRemoteFunction")) or (menu and menu:FindFirstChild("HoldItemRemoteFunction"))
                        if holdFn then
                            pcall(function()
                                holdFn:InvokeServer(toy, egg)
                            end)
                        end

                        task.wait(0.03)

                        local dropFn = (toy:FindFirstChild("HoldPart") and toy.HoldPart:FindFirstChild("DropItemRemoteFunction")) or (menu and menu:FindFirstChild("DropItemRemoteFunction"))
                        if dropFn then
                            pcall(function()
                                dropFn:InvokeServer(toy, hrp.CFrame * CFrame.new(TrainSettings.HeadOffset), Vector3.new(0, -6.55, 0))
                            end)
                        end
                    end
                end
            end

            local elapsed = tick() - cycleStart
            local remain = TrainSettings.Interval - elapsed
            task.wait(remain > 0 and remain or 0.01)
        end

        TrainSettings.LoopThread = nil
    end)
end

function TrainControlFeature.stopLoop()
    TrainSettings.Running = false
end

function TrainControlFeature.restoreNoClipState(modelRef, state)
    if modelRef then
        for part, st in pairs(state) do
            if part and part.Parent and typeof(st) == "table" then
                pcall(function()
                    part.CanCollide = st.CanCollide
                    part.CanQuery = st.CanQuery
                    part.CanTouch = st.CanTouch
                end)
            end
        end
    end
end

function TrainControlFeature.restoreVehicleNoClip()
    TrainControlFeature.restoreNoClipState(TrainSettings.NoClipVehicleModel, TrainSettings.NoClipVehicleState)
    TrainSettings.NoClipVehicleModel = nil
    TrainSettings.NoClipVehicleState = {}
end

function TrainControlFeature.restoreCharNoClip()
    TrainControlFeature.restoreNoClipState(TrainSettings.NoClipCharModel, TrainSettings.NoClipCharState)
    TrainSettings.NoClipCharModel = nil
    TrainSettings.NoClipCharState = {}
end

function TrainControlFeature.applyNoClipToModel(model, stateTable)
    if not model then return end
    for _, d in ipairs(model:GetDescendants()) do
        if d:IsA("BasePart") then
            if not stateTable[d] then
                stateTable[d] = {CanCollide = d.CanCollide, CanQuery = d.CanQuery, CanTouch = d.CanTouch}
            end
            d.CanCollide = false
            d.CanQuery = false
            d.CanTouch = false
        end
    end
end

-- ネットワークオーナーシップ
function TrainControlFeature.claimNetworkOwnershipSingle(part)
    if not part then return end
    pcall(function()
        part:SetNetworkOwner(LP)
    end)
end

function TrainControlFeature.claimNetworkOwnershipModel(model)
    if not model then return end
    
    pcall(function()
        for _, descendant in ipairs(model:GetDescendants()) do
            if descendant:IsA("BasePart") then
                pcall(function()
                    descendant:SetNetworkOwner(LP)
                end)
            end
        end
    end)
end

function TrainControlFeature.claimNetworkOwnership(part)
    if not part then return end
    
    TrainControlFeature.claimNetworkOwnershipSingle(part)
    
    local model = part:FindFirstAncestorOfClass("Model")
    if model then
        TrainControlFeature.claimNetworkOwnershipModel(model)
    end
end

function TrainControlFeature.startOwnershipThread(threadId, targetPart)
    if TrainSettings.OwnershipThreads[threadId] then return end
    
    TrainSettings.OwnershipThreads[threadId] = task.spawn(function()
        while TrainSettings.Enabled and targetPart and targetPart.Parent do
            TrainControlFeature.claimNetworkOwnership(targetPart)
            task.wait(TrainSettings.NetworkOwnershipInterval)
        end
        TrainSettings.OwnershipThreads[threadId] = nil
    end)
end

function TrainControlFeature.stopAllOwnershipThreads()
    for id, thread in pairs(TrainSettings.OwnershipThreads) do
        if thread then
            pcall(function()
                task.cancel(thread)
            end)
        end
    end
    TrainSettings.OwnershipThreads = {}
end

function TrainControlFeature.destroyVFly()
    if TrainSettings.BV then 
        pcall(function() TrainSettings.BV:Destroy() end)
        TrainSettings.BV = nil 
    end
    if TrainSettings.BG then 
        pcall(function() TrainSettings.BG:Destroy() end)
        TrainSettings.BG = nil 
    end
    TrainSettings.TargetPart = nil
    TrainSettings.VFlyEnabled = false
    TrainSettings.LastNetworkOwnership = 0
    TrainControlFeature.stopAllOwnershipThreads()
end

function TrainControlFeature.getTrainRootPart()
    local trainModel = TrainControlFeature.getTrainModel()
    if not trainModel then return nil end
    
    if trainModel.PrimaryPart then
        return trainModel.PrimaryPart
    end
    
    for _, child in ipairs(trainModel:GetDescendants()) do
        if child:IsA("BasePart") and child.Size.Magnitude > 5 then
            return child
        end
    end
    
    return nil
end

function TrainControlFeature.startVFlyForTrain()
    TrainControlFeature.destroyVFly()
    local part = TrainControlFeature.getTrainRootPart()
    if not part then 
        return 
    end

    TrainControlFeature.claimNetworkOwnership(part)

    TrainSettings.BV = Instance.new("BodyVelocity")
    TrainSettings.BV.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    TrainSettings.BV.P = TrainSettings.BV_P
    TrainSettings.BV.Velocity = Vector3.zero
    TrainSettings.BV.Parent = part

    TrainSettings.BG = Instance.new("BodyGyro")
    TrainSettings.BG.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    TrainSettings.BG.P = TrainSettings.BG_P
    TrainSettings.BG.CFrame = part.CFrame
    TrainSettings.BG.Parent = part

    TrainSettings.TargetPart = part
    TrainSettings.VFlyEnabled = true
    TrainSettings.LastNetworkOwnership = tick()
    
    for i = 1, TrainSettings.ParallelOwnershipThreads do
        TrainControlFeature.startOwnershipThread(i, part)
    end
end

function TrainControlFeature.hardStopAll()
    TrainSettings.Enabled = false
    TrainSettings.TrainEnableAt = 0
    TrainSettings.LastSitAttempt = 0
    TrainSettings.HadSeatOnce = false

    TrainControlFeature.destroyVFly()
    TrainControlFeature.stopLoop()
    TrainControlFeature.restoreCameraNoClip()
    TrainSettings.NoClip = false
    TrainControlFeature.stopAllOwnershipThreads()
end

